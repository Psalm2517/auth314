# Auth314 core service — environment variables.
# Copy to .env for local reference. Secrets must be set via `wrangler secret put`,
# NOT committed. Non-secret vars live in wrangler.toml [vars].

# --- Secrets (set with: wrangler secret put <NAME>) ---
# Reserved for server-authenticated Pi API calls (see worker/src/lib/pi.ts).
PI_API_KEY=

# --- Config (wrangler.toml [vars]) ---
PORTAL_BASE_URL=https://app.auth314.com
DASHBOARD_ORIGIN=https://dashboard.auth314.com

# The Pi OAuth client id and authorize URL are browser-side config:
# see portal/public/config.js.
